# ----- LLM provider configuration -----
# Default: Groq free tier. Get a free key at https://console.groq.com/keys
LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ----- Optional: run fully offline with local Ollama instead -----
# 1. Install Ollama (https://ollama.com) and run:  ollama pull llama3.1
# 2. Set the values below and change LLM_PROVIDER to "ollama"
# OLLAMA_MODEL=llama3.1
# OLLAMA_BASE_URL=http://localhost:11434/v1
